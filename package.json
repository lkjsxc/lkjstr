{
  "name": "lkjstr",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite dev",
    "kit:sync": "svelte-kit sync",
    "build": "vite build",
    "preview": "vite preview",
    "check": "pnpm kit:sync && svelte-check --tsconfig ./tsconfig.json",
    "check:repo": "tsx scripts/check-repo.ts",
    "lint": "pnpm kit:sync && eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:quiet": "tsx scripts/run-quiet.ts test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:memory": "playwright test tests/e2e/memory-gate.spec.ts tests/e2e/heavy-feed-memory.spec.ts tests/e2e/memory-churn.spec.ts",
    "test:e2e:quiet": "tsx scripts/run-quiet.ts e2e",
    "cloudflare:dry-run": "pnpm build && wrangler deploy --dry-run",
    "verify": "pnpm check:repo && pnpm lint && pnpm check && pnpm test && pnpm build",
    "verify:quiet": "tsx scripts/run-quiet.ts verify",
    "verify:e2e": "pnpm verify && pnpm test:e2e"
  },
  "dependencies": {
    "@lucide/svelte": "^1.16.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "dexie": "^4.2.1",
    "emoji-picker-element": "^1.29.1",
    "qrcode": "^1.5.4",
    "svelte-persisted-store": "^0.12.0",
    "virtua": "^0.49.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.49.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.43.14",
    "svelte-check": "^4.3.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.12",
    "vitest": "^4.0.7",
    "wrangler": "^4.93.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
